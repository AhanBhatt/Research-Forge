OPENAI_API_KEY=your_openai_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.2

# Keep arXiv API over HTTPS.
ARXIV_API_URL=https://export.arxiv.org/api/query
ARXIV_TIMEOUT_SECONDS=20
ARXIV_MAX_RETRIES=2
ARXIV_BACKOFF_SECONDS=2.0
ARXIV_MAX_RESULTS_PER_QUERY=16

# Neo4j is optional. Leave blank to disable graph memory.
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=
NEO4J_DATABASE=

EXPERIMENT_TIMEOUT_SECONDS=20
MAX_EXTRACTION_RETRIES=2

ARTIFACTS_DIR=artifacts
LOCAL_STRATEGY_CACHE_PATH=artifacts/local_strategy_cache.json
